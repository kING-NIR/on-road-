{
  "version": 2,
  "name": "roadassist-frontend",
  "builds": [
    {
      "src": "pages/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "js/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/pages/index.html" },
    { "src": "/emergency", "dest": "/pages/emergency.html" },
    { "src": "/map", "dest": "/pages/map.html" },
    { "src": "/profile", "dest": "/pages/profile.html" },
    { "src": "/admin", "dest": "/pages/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
